{
  "name": "knot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri-dev": "tauri dev",
    "tauri-build": "tauri build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "test:ci:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:browser": "playwright test --config=playwright.browser.config.ts",
    "test:e2e:tauri": "node scripts/tauri-native-smoke.mjs --check",
    "test:e2e:tauri:launch": "node scripts/tauri-native-smoke.mjs --launch-smoke --timeout=300",
    "qa:docsync": "node scripts/validate-ui-doc-sync.mjs",
    "qa:docsync:staged": "node scripts/validate-ui-doc-sync.mjs --staged",
    "qa:ci": "npm run -s typecheck && npm run -s lint && npm run -s test:ci:unit && npm run -s test:e2e:browser",
    "traceability:check-staged": "node scripts/validate-staged-traceability.mjs",
    "hooks:install": "bash scripts/install-githooks.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "lucide-react": "^0.575.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.3",
    "prosemirror-commands": "^1.5.0",
    "prosemirror-history": "^1.3.0",
    "prosemirror-keymap": "^1.2.0",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.0",
    "prosemirror-transform": "^1.7.0",
    "prosemirror-view": "^1.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "happy-dom": "^20.6.3",
    "jsdom": "^28.1.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
