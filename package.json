{
  "name": "knot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --host 127.0.0.1",
    "storybook:build": "storybook build",
    "storybook:smoke": "storybook dev --smoke-test -p 6006 --host 127.0.0.1",
    "storybook:test": "npm run -s storybook:smoke",
    "storybook:test:vitest": "vitest --project=storybook --run",
    "storybook:test:a11y": "STORYBOOK_A11Y_STRICT=1 vitest --project=storybook --run",
    "storybook:mcp:smoke": "node scripts/storybook-mcp-smoke.mjs",
    "knotd:mcp:smoke": "node scripts/knotd-mcp-smoke.mjs",
    "knotd:daemon:smoke": "node scripts/knotd-daemon-open-new-smoke.mjs",
    "knotd:mcp:startup-trace": "node scripts/knotd-mcp-startup-trace.mjs",
    "knotd:mcp:startup-trace:bridge": "KNOTD_STARTUP_TRACE_TRANSPORT=bridge node scripts/knotd-mcp-startup-trace.mjs",
    "knotd:triage": "node scripts/knotd-triage.mjs",
    "dev:daemon:up": "bash scripts/dev-up.sh",
    "dev:daemon:down": "bash scripts/dev-down.sh",
    "dev:daemon:restart": "bash scripts/dev-down.sh && bash scripts/dev-up.sh",
    "ui:daemon:smoke": "vitest run src/App.daemon-smoke.test.tsx",
    "codex:mcp:setup": "node scripts/setup-codex-storybook-mcp.mjs",
    "codex:mcp:setup:knotd": "node scripts/setup-codex-knotd-mcp.mjs",
    "codex:mcp:setup:all": "node scripts/setup-codex-storybook-mcp.mjs && node scripts/setup-codex-knotd-mcp.mjs",
    "tauri": "tauri",
    "tauri-dev": "tauri dev",
    "tauri-build": "node scripts/tauri-build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "coverage": "vitest --project=unit --run --coverage",
    "coverage:all": "vitest --project=unit --project=storybook --run --coverage",
    "coverage:check": "npm run -s coverage:all && node scripts/check-coverage-thresholds.mjs --statements 78 --functions 74 --lines 78 --branches 69",
    "test:ci:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:browser": "playwright test --config=playwright.browser.config.ts",
    "test:e2e:tauri": "node scripts/tauri-native-smoke.mjs --check",
    "test:e2e:tauri:launch": "node scripts/tauri-native-smoke.mjs --launch-smoke --timeout=300",
    "test:e2e:tauri:daemon": "node scripts/tauri-daemon-ipc-smoke.mjs --check",
    "test:e2e:tauri:daemon:launch": "node scripts/tauri-daemon-ipc-smoke.mjs --launch-smoke --timeout=300",
    "ci:local": "bash scripts/run-ci-local.sh",
    "qa:docsync": "node scripts/validate-ui-doc-sync.mjs",
    "qa:docsync:staged": "node scripts/validate-ui-doc-sync.mjs --staged",
    "qa:storybook-matrix": "node scripts/validate-storybook-coverage-matrix.mjs",
    "qa:ci": "npm run -s typecheck && npm run -s lint && npm run -s qa:storybook-matrix && npm run -s test:ci:unit && npm run -s test:e2e:browser",
    "traceability:check-staged": "node scripts/validate-staged-traceability.mjs",
    "hooks:install": "bash scripts/install-githooks.sh"
  },
  "dependencies": {
    "@benrbray/prosemirror-math": "^1.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "katex": "^0.16.33",
    "lucide-react": "^0.575.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.3",
    "pdfjs-dist": "^5.4.296",
    "prosemirror-commands": "^1.5.0",
    "prosemirror-history": "^1.3.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.0",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.0",
    "prosemirror-transform": "^1.7.0",
    "prosemirror-view": "^1.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-pdf": "^10.4.1",
    "yaml": "^2.8.2",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-mcp": "^0.3.1",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/react-vite": "^10.2.10",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "happy-dom": "^20.6.3",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.0.0",
    "storybook": "^10.2.10",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
